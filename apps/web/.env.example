NODE_ENV=development
NEXT_PUBLIC_SITE_URL=https://wheretostayeurope.com
SITE_URL=https://wheretostayeurope.com
LEGAL_ENTITY_NAME=
DATABASE_URL=
PAYLOAD_SECRET=
REVALIDATE_SECRET=
NEXT_PUBLIC_MAPBOX_TOKEN=
DEEPL_API_KEY=
UNSPLASH_ACCESS_KEY=
TURNSTILE_SECRET_KEY=
KIT_API_KEY=
KIT_FORM_ID_EN=
BOOKING_AFFILIATE_AID=
# Travelpayouts project marker (numeric project ID — visible in the dashboard
# as `?source=NNNNNN`, or in the Drive script base64 prefix). Default is 525153
# (Wheretostayeurope.com project). Set explicitly if running another project.
TRAVELPAYOUTS_MARKER=
# Travelpayouts partner ID (your account ID, visible in the dashboard sidebar
# next to your email). Used as `shmarker` on widget embeds. Default is 722878.
TRAVELPAYOUTS_PARTNER_ID=
GSC_VERIFICATION_TOKEN=
# Google AdSense publisher ID. Format: ca-pub-NNNNNNNNNNNNNNNN (the value
# in your AdSense dashboard's verification snippet). When set, the layout
# emits the AdSense <script> + <meta> tags and /ads.txt serves the
# matching DIRECT entry.
GOOGLE_ADSENSE_CLIENT_ID=